NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=re_your_resend_key

# Companies House Public Data API (server-only; used by GET /api/companies-house):
# COMPANIES_HOUSE_API_KEY=

# Optional — verified sender in Resend (defaults to onboarding@resend.dev):
# RESEND_FROM_EMAIL="Figures Reminders <notifications@your-domain.com>"

# Optional — require Authorization: Bearer <CRON_SECRET> on GET /api/send-digest:
# CRON_SECRET=

# Optional — always receive the digest at this address too (in addition to Settings +
# the built-in team list in lib/digest-recipients.ts). Comma / space / semicolon between addresses:
# DIGEST_EXTRA_EMAIL=ops@your-domain.com
# DIGEST_EXTRA_EMAIL=alice@example.com,bob@example.com
